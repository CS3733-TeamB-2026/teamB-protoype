// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "storage"]
}

model Employee {
  id        Int      @id
  firstName String
  lastName  String
  persona   Persona?

  ownedContent     Content[]
  ownedRequests    ServiceRequest[] @relation("OwnedBy")
  assignedRequests ServiceRequest[] @relation("AssignedTo")

  @@schema("public")
}

model Content {
  id      Int     @id @default(autoincrement())
  name    String
  linkURL String?

  owner   Employee? @relation(fields: [ownerID], references: [id])
  ownerID Int?

  lastModified DateTime  @default(now())
  expiration   DateTime?

  isWorkflow ContentType
  status     Status?

  @@schema("public")
}

//NEED TO FIX SPELLING OF asigneeID
model ServiceRequest {
  owner   Employee @relation("OwnedBy", fields: [ownerID], references: [id])
  ownerID Int

  assignee  Employee? @relation("AssignedTo", fields: [asigneeID], references: [id])
  asigneeID Int?

  created  DateTime    @default(now())
  deadline DateTime?
  type     RequestType

  @@id([ownerID, created])
  @@schema("public")
}

model objects {
  id               String   @id
  bucket_id        String
  name             String
  created_at       DateTime
  updated_at       DateTime
  last_accessed_at DateTime
  metadata         Json
  path_tokens      String[]
  version          String
  owner_id         String
  user_metadata    String

  @@schema("storage")
}

enum Persona {
  underwriter
  businessAnalyst

  @@schema("public")
}

enum Status {
  todo
  inProgress
  done

  @@schema("public")
}

enum ContentType {
  reference
  workflow

  @@schema("public")
}

enum RequestType {
  reviewClaim
  requestAdjuster
  checkClaim

  @@schema("public")
}
