// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

//TODO: will not be used once Auth0 is online
model Login {
  userName     String
  passwordHash String

  employee   Employee @relation(fields: [employeeID], references: [id], onDelete: Cascade)
  employeeID Int      @id

  @@schema("public")
}

model Employee {
  id              Int     @id
  auth0Id         String? @unique
  firstName       String
  lastName        String
  persona         Persona
  profilePhotoURI String?

  ownedContent      Content[] @relation("Owned")
  checkedOutContent Content[] @relation("CheckedOut")

  ownedRequests    ServiceRequest[] @relation("OwnedBy")
  assignedRequests ServiceRequest[] @relation("AssignedTo")

  login     Login?
  bookmarks Bookmark[]

  @@schema("public")
}

model Content {
  id          Int     @id @default(autoincrement())
  displayName String
  linkURL     String? @unique()
  fileURI     String? @unique()

  owner   Employee? @relation("Owned", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId Int?

  checkedOutById Int?
  checkedOutAt   DateTime?
  checkedOutBy   Employee? @relation("CheckedOut", fields: [checkedOutById], references: [id], onDelete: SetNull)

  lastModified DateTime
  expiration   DateTime?

  contentType   ContentType
  targetPersona Persona
  status        Status
  bookmarks     Bookmark[]

  tags String[]

  @@schema("public")
}

model ServiceRequest {
  id      Int      @id @default(autoincrement())
  owner   Employee @relation("OwnedBy", fields: [ownerId], references: [id])
  ownerId Int

  assignee   Employee? @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId Int?

  created  DateTime    @default(now())
  deadline DateTime?
  type     RequestType
  name     String?

  @@schema("public")
}

model Bookmark {
  bookmarker          Employee @relation(fields: [bookmarkerId], references: [id])
  bookmarkerId        Int
  bookmarkedContent   Content  @relation(fields: [bookmarkedContentId], references: [id])
  bookmarkedContentId Int

  @@id([bookmarkerId, bookmarkedContentId])
  @@schema("public")
}

enum Persona {
  underwriter
  businessAnalyst
  actuarialAnalyst
  EXLOperator
  businessOps
  admin

  @@schema("public")
}

enum Status {
  new
  inProgress
  complete

  @@schema("public")
}

enum ContentType {
  reference
  workflow

  @@schema("public")
}

enum RequestType {
  reviewClaim
  requestAdjuster
  checkClaim

  @@schema("public")
}
